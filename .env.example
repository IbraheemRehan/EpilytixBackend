# ──────────────────────────────────────────────
# Epilytix Server — Environment Variables
# ──────────────────────────────────────────────

# App
PORT=4000
NODE_ENV=development
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# MongoDB
MONGODB_URI=mongodb://localhost:27017/epilytix

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRY=7d

# 2FA
TWO_FACTOR_APP_NAME=Epilytix
OTP_EXPIRY_SECONDS=300

# CEO Seed
CEO_EMAIL=ibrahimrehan1230@gmail.com
CEO_DEFAULT_PASSWORD=EpilytixCEO@2024!
CEO_FIRST_NAME=Ibraheem
CEO_LAST_NAME=Rehan

# SMTP (for email OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Cloudinary (File Uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Throttle
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
LOGIN_THROTTLE_TTL=900000
LOGIN_THROTTLE_LIMIT=5
